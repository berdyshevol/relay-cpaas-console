# Relay runs with ZERO environment variables. Everything below is optional.

# Optional: override the salt used to derive the AES-256-GCM key that encrypts
# the per-visitor settings cookie. Defaults to a built-in demo salt.
# RELAY_COOKIE_SECRET=change-me-in-production

# NOTE: There is intentionally no Twilio or LLM API key here. Those are provided
# per-visitor (BYOK) through the in-app Settings panel and stored only in the
# visitor's own encrypted, HttpOnly cookie — never read from the deployer's env.
